{
  "_comment": "ATS-ready output: flat fields, no provenance, canonical skill names",
  "fields": [
    { "path": "full_name",     "type": "string",   "required": true },
    { "path": "primary_email", "from": "emails[0]","type": "string",   "required": true },
    { "path": "phone",         "from": "phones[0]","type": "string",   "normalize": "E164" },
    { "path": "github_url",    "from": "links.github",  "type": "string" },
    { "path": "linkedin_url",  "from": "links.linkedin","type": "string" },
    { "path": "headline",      "type": "string" },
    { "path": "years_experience", "type": "number" },
    { "path": "skills",        "from": "skills[].name", "type": "string[]", "normalize": "canonical" },
    { "path": "current_company",  "from": "experience[0].company", "type": "string" },
    { "path": "current_title",    "from": "experience[0].title",   "type": "string" },
    { "path": "latest_degree",    "from": "education[0].degree",   "type": "string" },
    { "path": "institution",      "from": "education[0].institution", "type": "string" }
  ],
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "null"
}
